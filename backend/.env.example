# ─────────────────────────────────────────────
# SafeCircle Backend — Environment Configuration
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Database (PostgreSQL + PostGIS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=safecircle
DB_USER=safecircle_app
DB_PASSWORD=change_me_in_production
DB_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT — Generate with: openssl genrsa -out private.key 2048 && openssl rsa -in private.key -pubout -out public.key
JWT_PRIVATE_KEY_PATH=./keys/private.key
JWT_PUBLIC_KEY_PATH=./keys/public.key
JWT_ACCESS_TOKEN_TTL=900         # 15 minutes in seconds
JWT_REFRESH_TOKEN_TTL=2592000    # 30 days in seconds

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Cloud Messaging (for push notifications)
FCM_SERVER_KEY=your-fcm-server-key

# AWS S3 / Cloudflare R2 Compatible Storage
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=safecircle-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_CDN_URL=https://cdn.safecircle.app

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@safecircle.app
EMAIL_FROM_NAME=SafeCircle

# Encryption — AES-256-GCM for location data at rest
# Generate with: openssl rand -hex 32
LOCATION_ENCRYPTION_KEY=your_64_char_hex_encryption_key_here_replace_in_prod

# hCaptcha (for CAPTCHA on risky flows)
HCAPTCHA_SECRET=your-hcaptcha-secret

# Rate limiting
THROTTLE_TTL=60000      # 1 minute in ms
THROTTLE_LIMIT=100

# Monitoring
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Analytics (PostHog — privacy-friendly)
POSTHOG_API_KEY=phc_xxxxxxxxxx
POSTHOG_HOST=https://app.posthog.com
